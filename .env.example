# ── Option 1: Groq (recommended — free, no credit card) ──────────────────────
# Sign up at https://console.groq.com → API Keys → Create key
GROQ_API_KEY=your_groq_key_here
# LLM_MODEL=llama-3.3-70b-versatile   # default — change to mixtral-8x7b etc.

# ── Option 2: OpenAI (paid) ───────────────────────────────────────────────────
# OPENAI_API_KEY=sk-...
# LLM_MODEL=gpt-4-turbo               # or gpt-4o-mini for lower cost

# ── Option 3: Ollama (local, fully offline) ───────────────────────────────────
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=llama3
# OPENAI_API_KEY=ollama               # placeholder — Ollama ignores the key
